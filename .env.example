# API Configuration
VITE_API_URL=http://localhost:8000/api/v1

# Laravel Reverb (WebSocket)
VITE_REVERB_APP_KEY=your-reverb-app-key
VITE_REVERB_HOST=localhost
VITE_REVERB_WS_PORT=8080
VITE_REVERB_WSS_PORT=443
VITE_REVERB_SCHEME=http

# Node Environment
NODE_ENV=development

# Optional: API timeout
VITE_API_TIMEOUT=10000

# Optional: WebSocket reconnection
VITE_WS_RECONNECTION_ATTEMPTS=5
VITE_WS_RECONNECTION_DELAY=1000
